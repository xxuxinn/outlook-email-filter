%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#4A90D9', 'primaryTextColor': '#fff', 'primaryBorderColor': '#2A5A9C', 'lineColor': '#666', 'secondaryColor': '#F5A623', 'tertiaryColor': '#F0F4F8', 'noteTextColor': '#333', 'noteBkgColor': '#FFF9E6' }}}%%

graph TB
    subgraph OUTLOOK["<b>Microsoft Outlook Process</b>"]
        direction TB

        subgraph EVENTS["ThisOutlookSession.bas<br/><i>Event Handlers Only</i>"]
            STARTUP["Application_Startup<br/><small>① LoadAllSettings<br/>② StartCommandPollerStd<br/>③ Init folder watchers<br/>④ SyncLearnedRulesAuto</small>"]
            INBOX_EVT["inboxItems_ItemAdd<br/><small>Real-time filter trigger</small>"]
            LK_EVT["learnKeepItems_ItemAdd"]
            LD_EVT["learnDeleteItems_ItemAdd"]
            LS_EVT["learnSubjectDeleteItems_ItemAdd"]
            LR_EVT["learnReplyItems_ItemAdd"]
            QUIT["Application_Quit<br/><small>StopPoller + SyncAuto</small>"]
        end

        subgraph CONFIG["Config.bas<br/><i>Constants & Variables Only</i>"]
            DEFAULTS["DEFAULT_* constants<br/><small>Compile-time fallbacks</small>"]
            RUNTIME["Runtime* variables<br/><small>Loaded from settings.ini</small>"]
        end

        subgraph UTILS["Utilities.bas<br/><i>Shared Infrastructure</i>"]
            direction LR
            STRING["String helpers<br/><small>ContainsAny, StartsWithAny<br/>SanitizeSubject, Truncate</small>"]
            LLM["CallLLM<br/><small>Multi-provider router</small>"]
            IO["File I/O<br/><small>INI read/write<br/>Learned rules I/O<br/>Reply pairs I/O</small>"]
            ERR["Error handling<br/><small>PushCallStack<br/>LogError, LogMessage</small>"]
            BRIDGE["Command Bridge<br/><small>SetTimer poller<br/>WriteResultFile</small>"]
        end

        subgraph FILTER["EmailFilter.bas<br/><i>Classification Engine</i>"]
            CLASSIFY["ClassifyEmail<br/><small>10-rule priority chain</small>"]
            EXEC["ExecuteAction<br/><small>KEEP / DELETE /<br/>MOVE_II / LLM_REVIEW</small>"]
            LLMWRAP["LLM Wrappers<br/><small>BuildEmailPrompt<br/>SummarizeSelectedEmail</small>"]
        end

        subgraph AGENT["EmailAgent.bas<br/><i>AI Agent Features</i>"]
            PATTERNS["GenerateAddressingPatterns"]
            REPLY["DraftAutoReply<br/><small>Few-shot reply engine</small>"]
            SCAN["ScanSentForReplyPatterns"]
            DRAFT["DraftReplyForSelected"]
        end

        subgraph BATCH["BatchFilter.bas<br/><i>Batch Macros & Wrappers</i>"]
            BATCHMAC["FilterExisting / FilterAllFolders<br/>FilterSelectedEmails<br/>FilterCurrentFolder<br/>FilterLastNDays<br/>DryRun / Report"]
        end
    end

    subgraph WEBUI["<b>Web UI — Python Flask</b><br/><small>localhost:5000</small>"]
        direction TB
        SERVER["server.py<br/><small>Flask routes</small>"]
        BRIDGEPY["bridge.py<br/><small>JSON command files</small>"]
        SETTINGS["settings_manager.py<br/><small>INI read/write</small>"]
        CHAT["chat.py<br/><small>Keyword→action parser</small>"]
        SPA["static/<br/><small>index.html + app.js<br/>6-tab SPA</small>"]
    end

    subgraph STORAGE["<b>Data Files</b><br/><small>%APPDATA%\OutlookEmailFilter\</small>"]
        INI["settings.ini"]
        SENDERS["learned_senders.txt"]
        SUBJECTS["learned_subjects.txt"]
        REPLIES["learned_replies.txt"]
        ERRORLOG["error.log"]
        CMDS["commands/*.json"]
    end

    subgraph CLOUD["<b>Cloud Sync</b><br/><small>OneDrive</small>"]
        CLOUDFILES["OutlookEmailFilter/<br/>learned_senders.txt<br/>learned_subjects.txt<br/>learned_replies.txt"]
    end

    subgraph LLM_PROVIDERS["<b>LLM Providers</b>"]
        LOCAL["Ollama / LM Studio<br/><small>localhost OpenAI-compat</small>"]
        AZURE["Azure OpenAI<br/><small>api-key auth</small>"]
        CLAUDE["Anthropic Claude<br/><small>x-api-key auth</small>"]
        OPENAI["OpenAI-compat<br/><small>OpenRouter, Groq, etc.</small>"]
    end

    %% Dependency flow
    STARTUP --> CONFIG
    STARTUP --> UTILS
    CONFIG --> UTILS
    UTILS --> FILTER
    UTILS --> AGENT
    FILTER --> BATCH
    AGENT --> BATCH
    INBOX_EVT --> CLASSIFY
    CLASSIFY --> EXEC
    BATCHMAC --> CLASSIFY

    %% LLM routing
    LLM --> LOCAL
    LLM --> AZURE
    LLM --> CLAUDE
    LLM --> OPENAI

    %% Data file connections
    IO --> INI
    IO --> SENDERS
    IO --> SUBJECTS
    IO --> REPLIES
    ERR --> ERRORLOG

    %% Command bridge
    BRIDGE --> CMDS
    BRIDGEPY --> CMDS

    %% Cloud sync
    IO --> CLOUDFILES

    %% Web UI flow
    SPA --> SERVER
    SERVER --> BRIDGEPY
    SERVER --> SETTINGS
    SERVER --> CHAT
    SETTINGS --> INI

    %% Learning events
    LK_EVT --> IO
    LD_EVT --> IO
    LS_EVT --> IO
    LR_EVT --> IO

    %% Agent uses LLM
    REPLY --> LLM
    PATTERNS --> LLM
    LLMWRAP --> LLM

    %% Styling
    classDef eventNode fill:#E8F5E9,stroke:#4CAF50,color:#1B5E20
    classDef configNode fill:#FFF3E0,stroke:#FF9800,color:#E65100
    classDef utilNode fill:#E3F2FD,stroke:#2196F3,color:#0D47A1
    classDef filterNode fill:#FCE4EC,stroke:#E91E63,color:#880E4F
    classDef agentNode fill:#F3E5F5,stroke:#9C27B0,color:#4A148C
    classDef batchNode fill:#E0F2F1,stroke:#009688,color:#004D40
    classDef webNode fill:#FFFDE7,stroke:#FBC02D,color:#F57F17
    classDef storageNode fill:#ECEFF1,stroke:#607D8B,color:#263238
    classDef cloudNode fill:#E8EAF6,stroke:#3F51B5,color:#1A237E
    classDef llmNode fill:#FFF8E1,stroke:#FFB300,color:#FF6F00

    class STARTUP,INBOX_EVT,LK_EVT,LD_EVT,LS_EVT,LR_EVT,QUIT eventNode
    class DEFAULTS,RUNTIME configNode
    class STRING,LLM,IO,ERR,BRIDGE utilNode
    class CLASSIFY,EXEC,LLMWRAP filterNode
    class PATTERNS,REPLY,SCAN,DRAFT agentNode
    class BATCHMAC batchNode
    class SERVER,BRIDGEPY,SETTINGS,CHAT,SPA webNode
    class INI,SENDERS,SUBJECTS,REPLIES,ERRORLOG,CMDS storageNode
    class CLOUDFILES cloudNode
    class LOCAL,AZURE,CLAUDE,OPENAI llmNode
